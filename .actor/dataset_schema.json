{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "schemaVersion": 1,
    "properties": {
      "fetchedAt": {
        "type": "string",
        "description": "ISO 8601 timestamp of when the data was fetched."
      },
      "mode": {
        "type": "string",
        "enum": ["live", "match", "standings", "player", "full"],
        "description": "The mode that produced this record."
      },
      "matches": {
        "type": "array",
        "description": "Match records (present for live, match, full modes)."
      },
      "standings": {
        "type": "array",
        "description": "Group stage standings rows (present for standings mode)."
      },
      "player": {
        "type": "object",
        "description": "Player tournament stats (present for player mode)."
      }
    },
    "required": ["fetchedAt", "mode"]
  },
  "views": {
    "overview": {
      "title": "Overview",
      "transformation": {
        "fields": ["fetchedAt", "mode", "matches", "standings", "player"]
      },
      "display": {
        "component": "table",
        "properties": {
          "fetchedAt": { "label": "Fetched At" },
          "mode": { "label": "Mode" },
          "matches": { "label": "Matches" },
          "standings": { "label": "Standings" },
          "player": { "label": "Player" }
        }
      }
    }
  }
}
